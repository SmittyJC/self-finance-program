import sqlite3

def show_users():
    conn = sqlite3.connect("finance.db")
    cursor = conn.cursor()

    print("\n=== USERS ===")
    cursor.execute("SELECT id, username FROM users;")
    for row in cursor.fetchall():
        print(row)

    conn.close()


def show_transactions():
    conn = sqlite3.connect("finance.db")
    cursor = conn.cursor()

    print("\n=== TRANSACTIONS ===")
    cursor.execute("""
        SELECT t.id, t.user_id, t.amount, t.date, t.description, t.type, c.name
        FROM transactions t
        LEFT JOIN categories c ON t.category_id = c.id;
    """)
    for row in cursor.fetchall():
        print(row)

    conn.close()


if __name__ == "__main__":
    show_users()
    show_transactions()
    print("\nDatabase test complete.\n")